# Environment configuration for paper_graph
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)

# -----------------------------------------------------------------------------
# Required for pipeline (LLM labeling uses gated HuggingFace models)
# -----------------------------------------------------------------------------
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# -----------------------------------------------------------------------------
# Database (Docker Compose provides defaults; override for custom setup)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# When using docker-compose: postgres service is at host "postgres"
# When running worker on host: use host "localhost"
DATABASE_URL=postgresql://pg:secret@localhost:5432/litsearch

# Alternative: set individually (used by run_pipeline_worker.py when DATABASE_URL unset)
# DB_HOST=localhost
# DB_USER=pg
# DB_PASSWORD=secret
# DB_NAME=litsearch

# -----------------------------------------------------------------------------
# API configuration
# -----------------------------------------------------------------------------
# Email for Crossref/OpenAlex API requests (polite crawlers)
PIPELINE_API_MAILTO=your-email@example.com

# -----------------------------------------------------------------------------
# Optional: frontend / development
# -----------------------------------------------------------------------------
# Backend API URL (frontend uses this to call the API)
# VITE_API_URL=http://localhost:8000

# Optional: vLLM server URL if using external LLM inference
# VLLM_BASE_URL=http://localhost:8100/v1

# Optional: CUDA memory allocation tuning
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
